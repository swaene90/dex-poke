@page "/games"
@using dex_poke.Shared.Services
@inject IUserGamesService UserGames

<PageTitle>My Games</PageTitle>

<h1>My Games</h1>
<p>Select the games you own. Hunt results will be filtered to these games.</p>

@foreach (var gen in GameData.AllGames.GroupBy(g => g.Generation).OrderBy(g => g.Key))
{
    <h3 style="margin-top:16px;">Generation @gen.Key</h3>
    <div style="display:flex; flex-wrap:wrap; gap:8px;">
        @foreach (var game in gen)
        {
            var owned = UserGames.OwnedGames.Contains(game.ApiName);
            <button @onclick="() => Toggle(game.ApiName)"
                    style="padding:6px 14px; border-radius:6px; border:2px solid @(owned ? "#5a9" : "#999");
                           background:@(owned ? "#d4f5e2" : "#f5f5f5"); cursor:pointer; font-weight:@(owned ? "bold" : "normal");">
                @game.DisplayName
            </button>
        }
    </div>
}

@code {
    private void Toggle(string apiName)
    {
        if (UserGames.OwnedGames.Contains(apiName))
            UserGames.RemoveGame(apiName);
        else
            UserGames.AddGame(apiName);
    }
}
